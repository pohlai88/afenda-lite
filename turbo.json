{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": [
		"DATABASE_URL",
		"NEON_AUTH_BASE_URL",
		"NEON_AUTH_COOKIE_SECRET",
		"APP_URL",
		"NEON_ORG_ID",
		"NEON_PROJECT_ID",
		"NEON_BRANCH_ID",
		"NEON_API_KEY",
		"PORTAL_ORG_SLUG",
		"PORTAL_ORG_NAME",
		"PORTAL_ORG_SWITCHER_ENABLED",
		"PORTAL_ORGANIZATION_ID",
		"E2E_ORGANIZATION_ID",
		"GUARDIAN_AUTH_SHELL",
		"FFT_RBAC_ENABLED",
		"FFT_DEPOSIT_ENABLED",
		"FFT_PICKUP_OPS_ENABLED",
		"FFT_NOTIFICATIONS_ENABLED",
		"FFT_EMAIL_FROM",
		"FFT_ERP_SYNC_ENABLED",
		"FFT_ERP_VENDOR",
		"FFT_ERP_BASE_URL",
		"FFT_ERP_API_KEY",
		"RESEND_API_KEY",
		"SHARED_ADMIN_EMAIL",
		"SHARED_ADMIN_NAME",
		"SHARED_ADMIN_PASSWORD",
		"PREVIEW_CLIENT_EMAIL",
		"PREVIEW_CLIENT_NAME",
		"PREVIEW_CLIENT_PASSWORD",
		"CLIENT_DEFAULT_PASSWORD",
		"CHECKLY_API_KEY",
		"CHECKLY_ACCOUNT_ID",
		"ENABLE_EXPERIMENTAL_COREPACK",
		"SKIP_ENV_VALIDATION",
		"VERCEL",
		"VERCEL_ENV",
		"VERCEL_URL",
		"CI"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:check": {
			"cache": false
		},
		"email:dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		}
	}
}
