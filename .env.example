# Supabase project: czxbufruvpcioghvfzmo
# Dashboard: https://supabase.com/dashboard/project/czxbufruvpcioghvfzmo
#
# Use the Supabase pooler URI for serverless (port 6543, transaction mode).
# Settings → Database → Connection string → URI → Pooler
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

NEXT_PUBLIC_SUPABASE_URL=https://czxbufruvpcioghvfzmo.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=

# Shared organization admin (run: npm run seed:admin)
SHARED_ADMIN_EMAIL=operator@afenda.cloud
SHARED_ADMIN_PASSWORD=<choose-a-strong-password>
SHARED_ADMIN_NAME=Portal Administrator

# Preview client sandbox for operator portal preview (run: npm run seed:preview-client)
PREVIEW_CLIENT_EMAIL=preview-client@example.com
PREVIEW_CLIENT_PASSWORD=<choose-a-strong-password>
PREVIEW_CLIENT_NAME=Preview Client

# Playground UI review route (/playground) — admin-gated, optional in production
PLAYGROUND_ENABLED=false
# Fixture IDs printed by npm run seed:preview-client
PLAYGROUND_SURVEY_ID=
PLAYGROUND_ASSIGNMENT_ID=
PLAYGROUND_SURVEY_SLUG=

# Public app URL for survey invite links (optional; Vercel sets VERCEL_URL automatically)
APP_URL=https://iam-check.vercel.app

# Temporary shared password for new clients (MVP — no Supabase email until SMTP)
CLIENT_DEFAULT_PASSWORD=Yhi8h!nb

# Optional MailerSend — auto-email client access on registration (HTTPS API, no SMTP)
# MAILERSEND_API_KEY=mlsn.xxxx
# MAILERSEND_FROM_EMAIL=noreply@your-trial-domain.mailersend.net
# MAILERSEND_FROM_NAME=iam-check

# Shadcn Studio MCP + block registry (components.json @ss-blocks)
SHADCN_STUDIO_API_KEY=
SHADCN_STUDIO_EMAIL=
LICENSE_KEY=

# Neon MCP (Cursor / VS Code)
NEON_API_KEY=

# Optional E2E overrides (CI uses SHARED_ADMIN_* by default)
# E2E_OPERATOR_EMAIL=
# E2E_OPERATOR_PASSWORD=
# E2E_SURVEY_SLUG=   # only if not using operator-create → public chain in smoke tests
