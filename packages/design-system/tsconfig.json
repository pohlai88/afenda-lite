{
	"extends": "@afenda/config/tsconfig/react-library.json",
	"compilerOptions": {
		"rootDir": "src",
		"paths": {
			"#assets/*": ["./src/assets/*"],
			"#blocks/*": ["./src/blocks/*"],
			"#components/*": ["./src/components/*"],
			"#config/*": ["./src/config/*"],
			"#contracts/*": ["./src/contracts/*"],
			"#controllers/*": ["./src/controllers/*"],
			"#hooks/*": ["./src/hooks/*"],
			"#lib/*": ["./src/lib/*"],
			"#providers/*": ["./src/providers/*"],
			"#shell/*": ["./src/shell/*"],
			"#stores/*": ["./src/stores/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
