{
	"extends": "@afenda/config/tsconfig/react-library.json",
	"compilerOptions": {
		"rootDir": "src",
		"paths": {
			"@/*": ["./src/*"],
			"#assets/*": ["./src/assets/*"],
			"#components/*": ["./src/components/*"],
			"#configs/*": ["./src/configs/*"],
			"#contexts/*": ["./src/contexts/*"],
			"#fake-db/*": ["./src/fake-db/*"],
			"#hooks/*": ["./src/hooks/*"],
			"#lib/*": ["./src/lib/*"],
			"#playground/*": ["./src/playground/*"],
			"#store/*": ["./src/store/*"],
			"#types/*": ["./src/types/*"],
			"#utils/*": ["./src/utils/*"],
			"#views/*": ["./src/views/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
