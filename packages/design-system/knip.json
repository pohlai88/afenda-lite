{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/views/**/index.{ts,tsx}",
		"src/fake-db/**/*.ts",
		"src/store/**/*.ts",
		"src/configs/**/*.{ts,tsx}",
		"src/assets/data/**/*.ts"
	],
	"project": ["src/**/*.{ts,tsx}"],
	"ignoreExportsUsedInFile": true,
	"ignoreBinaries": ["biome", "vitest"],
	"ignore": [
		"src/views/**",
		"src/components/layout/**",
		"src/assets/svg/**",
		"src/hooks/use-settings.ts",
		"src/utils/fonts.ts"
	]
}
