{
	"extends": "@afenda/config/tsconfig/nextjs.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./*"],
			"collections/*": ["./.source/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"next.config.mjs",
		"source.config.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".source/**/*.ts"
	],
	"exclude": ["node_modules"]
}
