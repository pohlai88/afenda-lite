{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "mode", "scope", "auditExitCode", "afendaRulesetHash", "operations", "unresolved"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "mode": { "const": "plan-fix" },
    "scope": { "type": "string", "minLength": 1 },
    "auditExitCode": { "enum": [0, 1] },
    "afendaRulesetHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "findingId", "kind", "fixType", "target", "beforeSha256", "afterSha256", "lockStatus", "href", "replacements"],
        "properties": {
          "id": { "type": "string", "pattern": "^FIX-[0-9]{3}$" },
          "findingId": { "type": "string", "pattern": "^DOC-CONS-[0-9]{3}$" },
          "kind": { "const": "unlink-missing-navigation-target" },
          "fixType": { "const": "AUTO" },
          "target": { "type": "string", "pattern": "(?:^|/)README\\.md$" },
          "beforeSha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "afterSha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "lockStatus": { "const": "Unlocked" },
          "href": { "type": "string", "minLength": 1 },
          "replacements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["from", "to", "occurrences"],
              "properties": {
                "from": { "type": "string", "minLength": 1 },
                "to": { "type": "string", "minLength": 1 },
                "occurrences": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "unresolved": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["findingId", "category", "fixType", "lockStatus", "conflictingSource", "authorityAspect", "authority", "evidence", "proposedResolution", "versionImpact", "registerImpact", "verification"],
        "properties": {
          "findingId": { "type": "string", "pattern": "^DOC-CONS-[0-9]{3}$" },
          "category": { "type": "string", "minLength": 1 },
          "fixType": { "enum": ["AUTO", "SEMI", "MANUAL", "ASK-LOCK"] },
          "lockStatus": { "type": "string", "minLength": 1 },
          "conflictingSource": { "type": "string", "minLength": 1 },
          "authorityAspect": { "type": "string", "minLength": 1 },
          "authority": { "type": "string", "minLength": 1 },
          "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "proposedResolution": { "type": "string", "minLength": 1 },
          "versionImpact": { "type": "string", "minLength": 1 },
          "registerImpact": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
